{
  "expo": {
    "name": "Помощник следователя",
    "slug": "pomoshniksledovatelya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pomoshniksledovatelya",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d2b45",
      "dark": {
        "image": "./assets/splash-icon.png",
        "backgroundColor": "#1a1a1a"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d2b45"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.Charlamycheva.forensichelper"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0d2b45",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#1a1a1a"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Приложению необходим доступ к галерее для прикрепления фотографий к протоколу.",
          "cameraPermission": "Приложению необходим доступ к камере для фиксации обстановки на месте происшествия."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b29ef18b-ea91-4a56-b2cd-65eb880f8def"
      }
    }
  }
}
